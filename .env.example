# ─── LLM Provider ────────────────────────────────────────────────────────────
# Primary: OpenRouter (supports 100+ models)
OPENROUTER_API_KEY=

# Optional fallback providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model to use (OpenRouter format: provider/model)
MODEL=deepseek/deepseek-chat
# Alternatives: openai/gpt-4o, anthropic/claude-3-opus, google/gemini-pro
EMBEDDING_MODEL=text-embedding-3-small
MODEL_PROVIDER=openrouter

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./qa_copilot.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/qa_copilot

# ─── Discord Bot (Optional) ──────────────────────────────────────────────────
DISCORD_TOKEN=

# ─── Environment & Logging ───────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── CORS ────────────────────────────────────────────────────────────────────
# Use "*" for development; restrict in production
CORS_ORIGINS=*

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800
